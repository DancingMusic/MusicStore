{
  "name": "@dancingmusic/music-store",
  "version": "0.4.0",
  "description": "Connector registry, submission validation, discovery, and distribution metadata for DancingMusic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "registry/schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:package": "tsup src/index.ts --format esm,cjs --dts --clean",
    "build": "npm run build:package && node scripts/generate-registry.mjs",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:registry": "npm run build:package && node scripts/generate-registry.mjs --check",
    "check": "npm run typecheck && npm test && npm run build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dancingmusic",
    "music",
    "store",
    "connector-registry",
    "manifest",
    "sdk"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
