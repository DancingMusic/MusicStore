{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/DancingMusic/MusicStore/main/registry/schema/connector-manifest.schema.json",
  "title": "DancingMusic connector manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "familyId", "variant", "authRequirement", "platforms", "name", "description", "publisher", "repository", "license", "version", "protocolVersion", "capabilities", "artifact", "status", "submittedAt", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "familyId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "variant": { "enum": ["anonymous", "account", "hybrid"] },
    "authRequirement": { "enum": ["none", "optional", "required"] },
    "platforms": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["web", "desktop"] }
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "repository": { "type": "string", "format": "uri", "pattern": "^https://" },
    "homepage": { "type": "string", "format": "uri", "pattern": "^https://" },
    "license": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" },
    "protocolVersion": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["search", "stream", "lyrics", "playlist", "login", "user-library", "recommendations"] }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "format"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "format": { "const": "esm" },
        "integrity": { "type": "string", "pattern": "^sha256-[A-Za-z0-9+/=]+$" },
        "mirrors": {
          "type": "array", "minItems": 1, "maxItems": 2,
          "items": {
            "type": "object", "additionalProperties": false, "required": ["region", "url"],
            "properties": {
              "region": { "enum": ["global", "china"] },
              "url": { "type": "string", "format": "uri", "pattern": "^https://" }
            }
          }
        }
      },
      "if": { "required": ["mirrors"] },
      "then": { "properties": { "integrity": true }, "required": ["integrity"] }
    },
    "releaseNotesUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "networkOrigins": { "type": "array", "items": { "type": "string", "format": "uri", "pattern": "^https://" }, "uniqueItems": true },
        "account": { "type": "boolean" }
      }
    },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "status": { "enum": ["active", "deprecated", "unlisted"] },
    "submittedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "variant": { "const": "anonymous" } } },
      "then": {
        "properties": {
          "authRequirement": { "const": "none" },
          "capabilities": { "not": { "contains": { "const": "login" } } }
        }
      }
    },
    {
      "if": { "properties": { "variant": { "const": "account" } } },
      "then": {
        "properties": {
          "authRequirement": { "const": "required" },
          "capabilities": { "contains": { "const": "login" } },
          "permissions": { "required": ["account"], "properties": { "account": { "const": true } } }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "active" } } },
      "then": {
        "properties": {
          "artifact": { "required": ["integrity"] }
        }
      }
    }
  ]
}
